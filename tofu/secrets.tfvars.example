# Copier ce fichier en secrets.tfvars et remplir les valeurs
# Le fichier secrets.tfvars est gitignored — ne jamais le commiter
#
# Les credentials OCI (tenancy, user, fingerprint, clé privée) ne sont PAS ici :
# le provider OpenTofu lit automatiquement ~/.oci/config profil DEFAULT.

# ── SSH ───────────────────────────────────────────────────────────────────────
ssh_public_key = "ssh-ed25519 AAAA... user@host"

# ── OCI Customer Secret Key (tofu backend S3 + restic backup) ─────────────────
# Console OCI → profil → My profile → Customer Secret Keys → Generate Secret Key
s3_access_key = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
s3_secret_key = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Minecraft RCON ────────────────────────────────────────────────────────────
rcon_password = "changeme-strong-password"

# ── Tailscale ─────────────────────────────────────────────────────────────────
# Générer : admin.tailscale.com → Settings → Keys → Generate auth key
tailscale_auth_key = "tskey-auth-XXXXXXXXXXXX-XXXXXXXXXXXX"

# ── Restic backup ─────────────────────────────────────────���───────────────────
# Mot de passe aléatoire fort (ex: openssl rand -base64 32)
restic_password = "changeme-strong-backup-password"
